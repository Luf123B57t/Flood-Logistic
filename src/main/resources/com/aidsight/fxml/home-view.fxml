<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.aidsight.presentation.controller.HomeViewController"
           prefWidth="1600" prefHeight="900" styleClass="home-container">

    <VBox alignment="CENTER" spacing="30">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <!-- Title -->
        <Label text="AidSight" styleClass="home-title">
            <VBox.margin>
                <Insets bottom="20"/>
            </VBox.margin>
        </Label>

        <!-- Description -->
        <Label styleClass="home-description" wrapText="true" maxWidth="800" textAlignment="CENTER"
               text="Welcome to AidSight. Analyze disaster-related data from Facebook posts and newspaper articles using advanced sentiment analysis and damage assessment. Track public sentiment over time and quantify disaster impacts including casualties, infrastructure damage, and agricultural losses. Click the button below to get started."/>

        <!-- Start Button -->
        <Button fx:id="startButton" text="Start" onAction="#onStartButtonClick"
                styleClass="start-button"
                prefWidth="180"
                prefHeight="50">
            <VBox.margin>
                <Insets top="10"/>
            </VBox.margin>
        </Button>
    </VBox>

</StackPane>

